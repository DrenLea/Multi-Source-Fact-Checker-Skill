# Google Fact Check Tools API key
GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_api_key_here

# Lens Protocol API key
LENS_API_KEY=your_lens_api_key_here

# Farcaster Hub URL
FARCASTER_HUB_URL=https://nemes.farcaster.xyz:2281

# zScore RPC endpoint
ZSCORE_RPC_URL=https://api.zscore.io/v1

# TraceRank mock endpoint
TRACERANK_ENDPOINT=https://api.tracerank.io/v1

# OpenAI API key (optional, for summary)
OPENAI_API_KEY=your_openai_api_key_here

# Log level
LOG_LEVEL=INFO
